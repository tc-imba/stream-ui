# Dev/preview server port. Defaults to 5274 if unset.
PORT=5274

VITE_BRIDGE_URL=ws://localhost:9696
VITE_BRIDGE_TOKEN=

# STS2Agent monitor WebSocket. Default matches STS2Agent's FastAPI port.
# Disabled when VITE_MOCK is on. Reconnects with exponential backoff.
# The log panel only displays `state` and `combat_plan` events; the rest
# (LLM calls, decisions, etc.) feed the model/token counters in the header
# but don't appear as visible rows. To change what's shown, edit
# VISIBLE_STS2_TYPES in src/store/logStore.ts.
VITE_STS2_WS_URL=ws://localhost:8081/ws/events

# Set to "false" to disable the mock event generator in dev mode.
# Mock is automatically off in production builds.
VITE_MOCK=
