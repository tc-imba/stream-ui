# Comma-separated bilibili room IDs to fetch.
# Keep under 10 rooms per node — bilibili will rate-limit beyond.
ROOMS=81516

# Bilibili login sync token from the LAPLACE Login Sync browser extension.
#
#   The fetcher's docs say this is "optional", but the current image
#   (sparanoid/laplace-event-fetcher:edge) crashes during startup if the
#   token is empty (it tries to mask a 0-length string). Required in practice.
#
# How to obtain:
#   1. Install LAPLACE Login Sync from the Chrome Web Store or Edge Add-ons
#   2. Log in to bilibili.com in the same browser
#   3. Open the extension, click "拷贝密钥" (Copy Key), then "保存并同步"
#   4. Paste the resulting key here
#
# Treat as a secret — it represents your bilibili session.
LOGIN_SYNC_TOKEN=
